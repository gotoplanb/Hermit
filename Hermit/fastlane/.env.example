# App Store Connect API Key
# Generate at https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY=  # base64-encoded .p8 file: base64 -i AuthKey_XXXXXX.p8

# Apple Developer Team
TEAM_ID=

# fastlane match — code signing via private Git repo
MATCH_GIT_URL=  # e.g. git@github.com:yourusername/hermit-certs.git
MATCH_PASSWORD=  # encryption password for the match repo
